# Firebase project config (used by migrate scripts running locally).
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
FIREBASE_PROJECT_ID=opsagent-prod

# Local Gemma URL (zero-key default per global rules).
GEMMA_LOCAL_URL=https://opsagent-ai-runtime-834557269016.us-central1.run.app
GEMMA_MODEL=gemma3:12b

# Optional cloud AI fallbacks — only set if OPSAGENT_AI_CLOUD=1.
OPSAGENT_AI_CLOUD=0
GROQ_API_KEY=
GEMINI_API_KEY=

# Migration script — only used by migrate/gcal-to-firestore.js.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
MIGRATE_OWNER_EMAIL=michal@msapps.mobi
